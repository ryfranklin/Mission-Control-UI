{
  "name": "web-spa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mission Control operator console — thin HTTP/SSE client of the Mission Control service seam.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "gen:api": "openapi-typescript \"${VITE_MC_SERVICE_BASE_URL:-http://localhost:8000}/openapi.json\" -o src/api/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "openapi-typescript": "^7.0.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
