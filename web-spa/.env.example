# Mission Control service seam — base URL of the local API the SPA talks to.
#
# This is the ONLY place the seam location is configured. The SPA is a thin
# HTTP/SSE client: the Vite dev server proxies seam routes (/runs, /targets,
# /metrics, /plans, /openapi.json, and their SSE feeds) to this URL, and
# `gen:api` reads <base>/openapi.json for typed client generation.
#
# Repo-agnostic + env-only: never commit a real host, account, or secret here.
# Copy this file to `.env.local` and adjust for your machine.
VITE_MC_SERVICE_BASE_URL=http://localhost:8000
